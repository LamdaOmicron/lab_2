DB_PORT=5432

# Приложение
APP_PORT=4200

# JWT
JWT_ACCESS_SECRET=your_super_secret_access_key_change_in_prod
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_in_prod
JWT_ACCESS_EXPIRATION=15
JWT_REFRESH_EXPIRATION=10080

# OAuth Yandex
YANDEX_CLIENT_ID=your_client_id
YANDEX_CLIENT_SECRET=your_client_secret
YANDEX_REDIRECT_URI=http://localhost:4200/auth/oauth/yandex/callback

